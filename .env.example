# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# OpenClaw config path
# Defaults to ~/.openclaw/openclaw.json then ~/.openclaw/moltbot.json
OPENCLAW_CONFIG_PATH=

# Request timeout (ms)
ROUTER_REQUEST_TIMEOUT_MS=30000

# Admin token for POST /reload-config (optional — leave empty to allow unauthenticated reload)
ROUTER_ADMIN_TOKEN=

# ── API key providers ──────────────────────────────────────────────────────────
# Only needed if NOT already inline in your OpenClaw config.
# Format: {PROVIDER_ID_UPPERCASE_UNDERSCORED}_API_KEY
ZAI_API_KEY=
KIMI_CODING_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# ── OAuth / token providers ────────────────────────────────────────────────────
# Providers that use OAuth (qwen-portal, openai-codex, anthropic token-mode)
# cannot do browser-based token refresh, but you can supply a static bearer token.
#
# How to get it:
#   - qwen-portal: open browser devtools on portal.qwen.ai → Network tab →
#     copy the Authorization header value from any API request
#   - openai-codex: same approach on platform.openai.com
#   - anthropic (token mode): set your API key here, it will be sent as a bearer token
#
# Format: {PROVIDER_ID_UPPERCASE_UNDERSCORED}_TOKEN
QWEN_PORTAL_TOKEN=
OPENAI_CODEX_TOKEN=
ANTHROPIC_TOKEN=
# Add more as needed for any OAuth provider in your OpenClaw config
