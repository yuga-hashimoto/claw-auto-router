{
  "name": "claw-auto-router",
  "version": "0.2.0",
  "description": "Self-hosted OpenAI-compatible LLM router that auto-imports providers from your OpenClaw config",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claw-auto-router": "dist/index.js",
    "clawr": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuga-hashimoto/claw-auto-router.git"
  },
  "homepage": "https://github.com/yuga-hashimoto/claw-auto-router#readme",
  "bugs": {
    "url": "https://github.com/yuga-hashimoto/claw-auto-router/issues"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
